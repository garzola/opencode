{
    "$schema": "https://opencode.ai/config.json",
    "model": "qwen3-coder-next:q4_K_M",
    "small_model": "devstral-small-2:24b",
    "enabled_providers": [
        "ollama"
    ],
    "provider": {
        "ollama": {
            "models": {
                "qwen3-coder-next:q4_K_M": {
                    "_launch": true,
                    "name": "qwen3-coder-next:q4_K_M",
                    "cost": {
                        "input": 0.03,
                        "output": 0.15,
                        "cache_read": 0.1
                    }
                },
                "devstral-small-2:24b": {
                    "_launch": true,
                    "name": "devstral-small-2:24b",
                    "cost": {
                        "input": 0.03,
                        "output": 0.15,
                        "cache_read": 0.1
                    }
                }
            },
            "name": "Ollama",
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://127.0.0.1:11434/v1"
            }
        }
    },
    "model": "ollama/qwen3-coder-next:q4_K_M",
    "default_agent": "devops-engineer",
    "autoupdate": true,
    "instructions": [
        "rules/*.md"
    ],
    // WARNING: this is a security risk, do not share sessions with anyone automatically.
    "share": "manual",
    "plugin": [
        "@franlol/opencode-md-table-formatter"
    ],
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp"
        },
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/home/gustavo/depots/github"
            ]
        },
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        }
        "fetch": {
            "command": "mcp-server-fetch"
        }
    }
}
