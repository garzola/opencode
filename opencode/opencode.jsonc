{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": true,
    "default_agent": "build",
    "disabled_providers": [],
    "username": "Gustavo",
    "agent": {
        "plan": {
            "model": "ollama/gemma4:26b"
        },
        "general": {
            "model": "ollama/phi4-reasoning:14b"
        },
        "build": {
            "model": "ollama/qwen3.5:35b-a3b-coding-nvfp4"
        }
    },
    "enabled_providers": [
        "ollama"
    ],
    "instructions": [
        "rules/*.md"
    ],
    "mcp": {
        "context7": {
            "enabled": true,
            "type": "remote",
            "url": "https://mcp.context7.com/mcp"
        },
        "fetch": {
            "command": [
                "mcp-server-fetch"
            ],
            "enabled": true,
            "type": "local"
        },
        "filesystem": {
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/home/gustavo/.opencode",
                "/home/gustavo/depots/github"
            ],
            "enabled": true,
            "type": "local"
        },
        "sequential-thinking": {
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ],
            "enabled": true,
            "type": "local"
        }
    },
    "model": "ollama/qwen3.5:35b-a3b-coding-nvfp4",
    "provider": {
        "ollama": {
            "models": {
                "codestral:22b": {
                    "cost": {
                        "cache_read": 0.1,
                        "input": 0.03,
                        "output": 0.15
                    },
                    "name": "Codestral (22b)"
                },
                "cogito:32b": {
                    "cost": {
                        "cache_read": 0.1,
                        "input": 0.03,
                        "output": 0.15
                    },
                    "name": "Cogito (32b)"
                },
                "devstral-small-2:24b": {
                    "cost": {
                        "cache_read": 0.1,
                        "input": 0.03,
                        "output": 0.15
                    },
                    "name": "Devstral Small 2 (24b)"
                },
                "gemma4:26b": {
                    "cost": {
                        "cache_read": 0.1,
                        "input": 0.03,
                        "output": 0.15
                    },
                    "name": "Gemma 4 (26b)"
                },
                "gemma4:e4b": {
                    "cost": {
                        "cache_read": 0.1,
                        "input": 0.03,
                        "output": 0.15
                    },
                    "name": "Gemma 4 (e4b)"
                },
                "phi4-reasoning:14b": {
                    "cost": {
                        "cache_read": 0.1,
                        "input": 0.03,
                        "output": 0.15
                    },
                    "name": "Phi 4 Reasoning (14b)"
                },
                "qwen3.5:35b-a3b-coding-nvfp4": {
                    "cost": {
                        "cache_read": 0.1,
                        "input": 0.03,
                        "output": 0.15
                    },
                    "name": "Qwen 3.5 Coder (a3b 35b)"
                }
            },
            "name": "Ollama",
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://gratik.scby.com:11434/v1"
            }
        }
    },
    "small_model": "ollama/ollama/phi4-reasoning:14b"
}
